# 推荐（与中台 Web 一致）：API 根，常含 /api
# 列表：GET ${VITE_API_BASE_URL}/scquery/enterprises
# VITE_API_BASE_URL=https://oa.diantongxue.com/api
# 同源开发可写：VITE_API_BASE_URL=/api
#
# 可选：每页条数，默认 100，最大 500
# VITE_SCQUERY_PAGE_SIZE=100
#
# 兼容旧配置（与 VITE_API_BASE_URL 二选一即可）：
# 站点根不含 /api → 自动请求 ${VITE_SC_API_BASE}/api/scquery/enterprises
# VITE_SC_API_BASE=https://oa.diantongxue.com
#
# 或直接写完整 SC 前缀（不含 /enterprises）：
# VITE_SCQUERY_API_BASE=/api/scquery
# VITE_SCQUERY_API_BASE=https://oa.diantongxue.com/api/scquery
#
# 以上均未配置时，SC 查询使用内置演示数据，不请求网络。
